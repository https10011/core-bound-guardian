    "@capacitor/status-bar": "^6",
    "bcryptjs": "^2.4.3",
    "jeep-sqlite": "^2.7.2",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^18.3.5",
